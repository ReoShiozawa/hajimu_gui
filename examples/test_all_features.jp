// ==========================================================================
// test_all_features.jp — hajimu_gui 全機能テストスイート
//
// 使い方:
//   hajimu examples/test_all_features.jp
//
// Phase 1-19 の全登録関数を実際に呼び出し、動作を確認する。
// ==========================================================================

取り込む "hajimu_gui" として GUI

// ── 状態変数 ──────────────────────────────────────
変数 アプリ = GUI.アプリ作成("hajimu_gui 全機能テスト v1.0", 1024, 768)
変数 タブ選択 = 0
変数 カウンタ = 0
変数 チェックA = 偽
変数 チェックB = 真
変数 ラジオ値 = "選択肢A"
変数 スライダー値 = 40
変数 テキスト値 = ""
変数 パス値 = ""
変数 入力値 = 42
変数 エリア値 = "複数行テキスト"
変数 コンボ値 = "りんご"
変数 リスト選択 = -1
変数 テーブルID = -1
変数 ツリーID = -1
変数 データ初期化済 = 偽
変数 モーダル表示 = 偽
変数 最後のメニュー = "なし"
変数 現在のテーマ = "ダーク"
変数 フォントGrサイズ = 14
変数 クリップ内容 = ""
変数 アニメ有効 = 偽
変数 タイマーIDval = ""
変数 トグル値 = 偽
変数 色値 = GUI.色16進("#3388ff")
変数 折りたたみ開 = 真
変数 選択A = 偽
変数 選択B = 偽
変数 タグ1 = 真
変数 タグ2 = 真
変数 スプリット比 = 0.4
変数 検索テキスト = ""
変数 AC値 = ""
変数 ドラッグ値 = 2.5
変数 日付値 = "2026-02-21"
変数 時刻値 = "12:00"
変数 無効フラグ = 真
変数 ナビ選択 = 0
変数 ステッパー値 = 1

// ==========================================================================
// メイン描画ループ
// ==========================================================================
GUI.描画ループ(アプリ, 関数():

    // ── データ初期化 (初回のみ) ──
    もし データ初期化済 == 偽 なら
        テーブルID = GUI.テーブル作成("test_table", ["ID", "名前", "スコア", "ステータス"])
        GUI.テーブル行追加(テーブルID, ["1", "Alice",   "95", "合格"])
        GUI.テーブル行追加(テーブルID, ["2", "Bob",     "72", "合格"])
        GUI.テーブル行追加(テーブルID, ["3", "Charlie", "58", "不合格"])
        GUI.テーブル行追加(テーブルID, ["4", "Diana",   "88", "合格"])
        GUI.テーブル行追加(テーブルID, ["5", "Eve",     "41", "不合格"])
        ツリーID = GUI.ツリー作成("test_tree")
        変数 n1 = GUI.ツリーノード追加(ツリーID, -1, "Phase 1-5: コア")
        GUI.ツリーノード追加(ツリーID, n1, "アプリ作成 OK")
        GUI.ツリーノード追加(ツリーID, n1, "描画ループ OK")
        GUI.ツリーノード追加(ツリーID, n1, "ウィジェット OK")
        変数 n2 = GUI.ツリーノード追加(ツリーID, -1, "Phase 6-10: 中級")
        GUI.ツリーノード追加(ツリーID, n2, "タブ・メニュー OK")
        GUI.ツリーノード追加(ツリーID, n2, "カスタム描画 OK")
        GUI.ツリーノード追加(ツリーID, n2, "アニメーション OK")
        変数 n3 = GUI.ツリーノード追加(ツリーID, -1, "Phase 11-19: 上級")
        GUI.ツリーノード追加(ツリーID, n3, "高度レイアウト OK")
        GUI.ツリーノード追加(ツリーID, n3, "チャート OK")
        GUI.ツリーノード追加(ツリーID, n3, "ナビゲーション OK")
        データ初期化済 = 真
    終わり

    // ── ステータスバー (Ph12) ──
    GUI.ステータスバー開始()
    GUI.テキスト("hajimu_gui 全機能テスト Phase 1-19")
    GUI.色付きテキスト("テーマ: " + 現在のテーマ, GUI.色(150, 200, 255, 255))
    GUI.ステータスバー終了()

    // ── メニューバー (Ph6) ──
    GUI.メニューバー開始()
    もし GUI.メニュー("テーマ") なら
        もし GUI.メニュー項目("ダーク", "Ctrl+D") なら
            GUI.テーマ設定("ダーク")
            現在のテーマ = "ダーク"
            最後のメニュー = "ダークテーマ"
        終わり
        もし GUI.メニュー項目("ライト", "Ctrl+L") なら
            GUI.テーマ設定("ライト")
            現在のテーマ = "ライト"
            最後のメニュー = "ライトテーマ"
        終わり
        GUI.メニューセパレーター()
        もし GUI.メニュー項目("高コントラスト") なら
            GUI.テーマ設定("高コントラスト")
            現在のテーマ = "高コントラスト"
        終わり
    終わり
    もし GUI.メニュー("テスト") なら
        もし GUI.メニュー項目("クリップボードコピー") なら
            GUI.クリップボード設定("hajimu_gui テスト文字列")
            最後のメニュー = "クリップボード書き込み済"
        終わり
        もし GUI.メニュー項目("トースト表示") なら
            GUI.トースト("メニューからテスト通知！", 3)
            最後のメニュー = "トースト表示"
        終わり
    終わり
    GUI.メニューバー終了()

    // ── ヘッダー ──
    GUI.見出し("hajimu_gui 全機能テストスイート", 1)
    GUI.色付きテキスト("Phase 1-19 の登録関数を網羅的に確認するテストコード", GUI.色(150, 180, 255, 220))
    GUI.セパレーター()

    // ── Ctrl+S ショートカット (Ph9) ──
    もし GUI.ショートカット("s", "Ctrl") なら
        GUI.トースト("Ctrl+S OK", 2)
    終わり

    // ── ツールバー (Ph12) ──
    GUI.ツールバー開始()
    もし GUI.小ボタン("保存") なら
        GUI.トースト("ツールバー:保存 OK", 1)
    終わり
    もし GUI.小ボタン("コピー") なら
        GUI.クリップボード設定("ツールバーからコピー")
    終わり
    GUI.ツールバー終了()

    // ──────────────────────────────────────────────────────
    // タブバー (Phase 6)
    // ──────────────────────────────────────────────────────
    タブ選択 = GUI.タブバー("main_tabs", ["Ph1-2基本", "Ph3-4入力", "Ph5データ", "Ph6-7描画", "Ph8-9スタイル", "Ph10-11アニメ", "Ph12-13レイアウト", "Ph14チャート", "Ph15-16リッチ", "Ph17-19システム"], タブ選択)

    // ══════════════════════════════════════════════════════
    // タブ 0: Phase 1-2 — コア・基本ウィジェット
    // ══════════════════════════════════════════════════════
    もし GUI.タブ内容(タブ選択, 0) なら
        GUI.ブレッドクラム(["ホーム", "Phase 1-2", "基本ウィジェット"])
        GUI.セパレーター()

        // Phase 1: コア
        GUI.区切りテキスト("Phase 1: コア API")
        変数 サイズ = GUI.ウィンドウサイズ(アプリ)
        GUI.テキスト("ウィンドウサイズ: " + 文字列化(サイズ))
        変数 dpi = GUI.DPIスケール()
        GUI.テキスト("DPI スケール: " + 文字列化(dpi))
        GUI.フレームレート(アプリ, 60)
        GUI.テキスト("フレームレート: 60fps に設定")
        GUI.スペーサー()

        // Phase 2: ウィジェット
        GUI.区切りテキスト("Phase 2: ウィジェット")
        GUI.横並び開始()
        もし GUI.ボタン("カウントアップ") なら
            カウンタ = カウンタ + 1
        終わり
        もし GUI.ボタン("リセット") なら
            カウンタ = 0
        終わり
        GUI.テキスト("  カウンタ: " + 文字列化(カウンタ))
        GUI.横並び終了()

        チェックA = GUI.チェックボックス("チェックA (初期:偽)", チェックA)
        チェックB = GUI.チェックボックス("チェックB (初期:真)", チェックB)
        GUI.テキスト("A:" + 文字列化(チェックA) + "  B:" + 文字列化(チェックB))

        GUI.横並び開始()
        ラジオ値 = GUI.ラジオボタン("選択肢A", "test_radio", ラジオ値)
        ラジオ値 = GUI.ラジオボタン("選択肢B", "test_radio", ラジオ値)
        ラジオ値 = GUI.ラジオボタン("選択肢C", "test_radio", ラジオ値)
        GUI.横並び終了()
        GUI.テキスト("ラジオ選択中: " + ラジオ値)

        スライダー値 = GUI.スライダー("スライダー", スライダー値, 0, 100)
        GUI.プログレスバー(スライダー値, 100)
        GUI.テキスト("スライダー値: " + 文字列化(スライダー値))

        GUI.スペーサー(6)
        GUI.セパレーター()
        もし GUI.ボタン("ツールチップ付きボタン (ホバーで確認)") なら
            GUI.トースト("ボタン押下 OK", 1)
        終わり
        GUI.ツールチップ("これは Phase 2 のツールチップです")

        GUI.スペーサー()
        GUI.区切りテキスト("テキスト種別 (Ph16)")
        GUI.色付きテキスト("色付きテキスト (赤)", GUI.色(220, 80, 80, 255))
        GUI.折返しテキスト("これは長い折り返しテキストです。ウィンドウ幅に合わせて自動的に折り返されます。正常表示で Phase 16 折返しテキストが動作確認できます。")
        GUI.無効テキスト("無効化されたグレーのテキスト (Ph16)")
        GUI.箇条書き("箇条書きテキスト (Ph16 bullet)")
        GUI.テキスト選択("コピー可能なテキスト - ドラッグで選択 (Ph16)")
    終わり

    // ══════════════════════════════════════════════════════
    // タブ 1: Phase 3-4 — テキスト入力・レイアウト
    // ══════════════════════════════════════════════════════
    もし GUI.タブ内容(タブ選択, 1) なら
        GUI.ブレッドクラム(["ホーム", "Phase 3-4", "入力・レイアウト"])
        GUI.セパレーター()

        GUI.区切りテキスト("Phase 3: テキスト入力")
        テキスト値 = GUI.テキスト入力("テキスト入力", テキスト値)
        パス値 = GUI.パスワード入力("パスワード", パス値)
        入力値 = GUI.数値入力("数値入力", 入力値, 0, 999, 1)
        エリア値 = GUI.テキストエリア("テキストエリア", エリア値)
        コンボ値 = GUI.コンボボックス("コンボボックス", ["りんご", "みかん", "ぶどう", "バナナ", "メロン"], コンボ値)
        GUI.テキスト("テキスト:[" + テキスト値 + "]  コンボ:" + コンボ値 + "  数値:" + 文字列化(入力値))

        GUI.スペーサー()
        GUI.区切りテキスト("Phase 4: レイアウト")
        GUI.パネル開始("外側パネル")
        GUI.テキスト("外側パネルのテキスト")
        GUI.インデント()
        GUI.テキスト("インデントされたテキスト (lvl1)")
        GUI.インデント()
        GUI.テキスト("さらにインデント (lvl2)")
        GUI.インデント解除()
        GUI.インデント解除()
        GUI.テキスト("インデント解除後")
        GUI.パネル終了()

        GUI.スペーサー()
        GUI.区切りテキスト("横並び (Ph4)")
        GUI.横並び開始()
        もし GUI.ボタン("A") なら
            GUI.トースト("A OK", 1)
        終わり
        もし GUI.ボタン("B") なら
            GUI.トースト("B OK", 1)
        終わり
        もし GUI.ボタン("C") なら
            GUI.トースト("C OK", 1)
        終わり
        GUI.小ボタン("small")
        GUI.横並び終了()

        変数 マウス = GUI.マウス位置()
        変数 クリック = GUI.マウスクリック()
        GUI.テキスト("マウス位置: " + 文字列化(マウス))
        GUI.テキスト("マウスクリック: " + 文字列化(クリック))

        GUI.スペーサー()
        GUI.区切りテキスト("テキスト揃え (Ph12)")
        GUI.中央揃え()
        GUI.ボタン("中央揃えボタン")
        GUI.右揃え()
        GUI.ボタン("右揃えボタン")
    終わり

    // ══════════════════════════════════════════════════════
    // タブ 2: Phase 5 — データ (リスト・テーブル・ツリー)
    // ══════════════════════════════════════════════════════
    もし GUI.タブ内容(タブ選択, 2) なら
        GUI.ブレッドクラム(["ホーム", "Phase 5", "データ表示"])
        GUI.セパレーター()
        GUI.区切りテキスト("Phase 5: リスト・テーブル・ツリー")

        GUI.パネル開始("リスト選択")
        リスト選択 = GUI.リスト("果物リスト", ["りんご", "みかん", "ぶどう", "いちご", "バナナ", "メロン", "すいか", "もも"], リスト選択)
        もし リスト選択 >= 0 なら
            GUI.テキスト("選択: index=" + 文字列化(リスト選択))
        終わり
        GUI.パネル終了()

        GUI.スペーサー()
        GUI.区切りテキスト("テーブル (ヘッダークリックでソート)")
        変数 選択行 = GUI.テーブル描画(テーブルID)
        もし 選択行 >= 0 なら
            GUI.テキスト("選択行: " + 文字列化(選択行))
        終わり
        GUI.横並び開始()
        もし GUI.小ボタン("名前順") なら
            GUI.テーブルソート(テーブルID, 1, 真)
        終わり
        もし GUI.小ボタン("スコア降順") なら
            GUI.テーブルソート(テーブルID, 2, 偽)
        終わり
        GUI.横並び終了()

        GUI.スペーサー()
        GUI.区切りテキスト("ツリービュー")
        変数 選択ノード = GUI.ツリー描画(ツリーID)
        もし 選択ノード >= 0 なら
            GUI.テキスト("選択ノード ID: " + 文字列化(選択ノード))
        終わり
    終わり

    // ══════════════════════════════════════════════════════
    // タブ 3: Phase 6-7 — ダイアログ・カスタム描画
    // ══════════════════════════════════════════════════════
    もし GUI.タブ内容(タブ選択, 3) なら
        GUI.ブレッドクラム(["ホーム", "Phase 6-7", "描画・ダイアログ"])
        GUI.セパレーター()

        GUI.区切りテキスト("Phase 6: ダイアログ・通知")
        GUI.横並び開始()
        もし GUI.ボタン("モーダルダイアログ") なら
            モーダル表示 = 真
        終わり
        もし GUI.ボタン("ファイルダイアログ") なら
            変数 選択パス = GUI.ファイルダイアログ()
            もし 選択パス != "" なら
                GUI.トースト("選択: " + 選択パス, 3)
            終わり
        終わり
        もし GUI.ボタン("メッセージBox") なら
            GUI.メッセージ("確認", "これはメッセージダイアログのテストです。", "情報")
        終わり
        GUI.横並び終了()
        GUI.テキスト("最後のメニュー操作: " + 最後のメニュー)

        GUI.スペーサー()
        GUI.区切りテキスト("Phase 7: カスタム描画 (キャンバス)")
        GUI.キャンバス開始("test_canvas", 600, 300)

        変数 赤 = GUI.色(220, 60, 60, 255)
        変数 青 = GUI.色(60, 120, 230, 255)
        変数 緑 = GUI.色(60, 200, 100, 255)
        変数 黄 = GUI.色(255, 210, 60, 255)
        変数 紫 = GUI.色(160, 60, 200, 255)
        変数 白 = GUI.色(255, 255, 255, 200)

        // 矩形・枠・角丸
        GUI.矩形(10, 10, 80, 60, 赤)
        GUI.矩形枠(100, 10, 80, 60, 青, 2)
        GUI.角丸矩形(190, 10, 80, 60, 12, 緑)
        // 円・円弧
        GUI.円(50, 130, 35, 青)
        GUI.円弧(150, 130, 35, 0, 3.14, 赤)
        GUI.円弧(250, 130, 35, 0, 6.28, 紫)
        // 線
        GUI.線(300, 10, 580, 80, 黄, 3)
        GUI.線(300, 80, 580, 10, 白, 1)
        // パス (三角形)
        GUI.パス開始()
        GUI.パス移動(350, 180)
        GUI.パス線(420, 80)
        GUI.パス線(490, 180)
        GUI.パス終了(緑, 赤)
        // ベジェ曲線
        GUI.ベジェ(10, 200, 100, 120, 200, 280, 300, 200)
        // テキスト描画
        GUI.描画テキスト("Phase 7 描画テスト", 5, 255)
        // 変換テスト
        GUI.変換保存()
        GUI.平行移動(480, 240)
        GUI.回転(0.5)
        GUI.拡縮(1.2, 1.2)
        GUI.矩形(-20, -15, 40, 30, 黄)
        GUI.変換復元()

        GUI.キャンバス終了()
    終わり

    // ══════════════════════════════════════════════════════
    // タブ 4: Phase 8-9 — テーマ・クリップ・カーソル
    // ══════════════════════════════════════════════════════
    もし GUI.タブ内容(タブ選択, 4) なら
        GUI.ブレッドクラム(["ホーム", "Phase 8-9", "スタイル・操作系"])
        GUI.セパレーター()

        // Phase 8: テーマ
        GUI.区切りテキスト("Phase 8: テーマ設定")
        GUI.テキスト("現在のテーマ: " + 現在のテーマ)
        GUI.横並び開始()
        もし GUI.ボタン("ダーク") なら
            GUI.テーマ設定("ダーク")
            現在のテーマ = "ダーク"
        終わり
        もし GUI.ボタン("ライト") なら
            GUI.テーマ設定("ライト")
            現在のテーマ = "ライト"
        終わり
        もし GUI.ボタン("高コントラスト") なら
            GUI.テーマ設定("高コントラスト")
            現在のテーマ = "高コントラスト"
        終わり
        GUI.横並び終了()
        変数 OSテーマ = GUI.OSテーマ取得()
        GUI.テキスト("OSテーマ: " + 文字列化(OSテーマ))

        GUI.スペーサー()
        GUI.区切りテキスト("フォント設定 (Ph8)")
        フォントGrサイズ = GUI.数値入力("フォントサイズ", フォントGrサイズ, 8, 32, 1)
        GUI.フォントサイズ(フォントGrサイズ)
        GUI.テキスト("フォントサイズ: " + 文字列化(フォントGrサイズ) + "pt")

        // Phase 9: クリップボード
        GUI.スペーサー()
        GUI.区切りテキスト("Phase 9: クリップボード")
        GUI.横並び開始()
        もし GUI.ボタン("コピー") なら
            GUI.クリップボード設定("はじむGUI テストテキスト " + 文字列化(カウンタ))
            GUI.トースト("コピーしました！", 2)
        終わり
        もし GUI.ボタン("ペースト") なら
            クリップ内容 = GUI.クリップボード取得()
        終わり
        GUI.横並び終了()
        GUI.テキスト("クリップボード: " + クリップ内容)

        GUI.スペーサー()
        GUI.区切りテキスト("カーソル変更 (Ph9)")
        GUI.横並び開始()
        もし GUI.ボタン("矢印") なら
            GUI.カーソル設定("矢印")
        終わり
        もし GUI.ボタン("手") なら
            GUI.カーソル設定("手")
        終わり
        もし GUI.ボタン("テキスト") なら
            GUI.カーソル設定("テキスト")
        終わり
        もし GUI.ボタン("十字") なら
            GUI.カーソル設定("十字")
        終わり
        GUI.横並び終了()

        GUI.スペーサー()
        GUI.区切りテキスト("キー入力検出 (Ph9)")
        もし GUI.キー押下("上") なら
            GUI.トースト("上キー検出", 1)
        終わり
        もし GUI.キー押下("下") なら
            GUI.トースト("下キー検出", 1)
        終わり
        もし GUI.キー押下("左") なら
            GUI.トースト("左キー検出", 1)
        終わり
        もし GUI.キー押下("右") なら
            GUI.トースト("右キー検出", 1)
        終わり
        GUI.テキスト("矢印キーで通知トースト表示")
        変数 左クリック = GUI.マウスボタン("左")
        変数 右クリック = GUI.マウスボタン("右")
        GUI.テキスト("マウス: 左=" + 文字列化(左クリック) + " 右=" + 文字列化(右クリック))
    終わり

    // ══════════════════════════════════════════════════════
    // タブ 5: Phase 10-11 — アニメーション・追加ウィジェット
    // ══════════════════════════════════════════════════════
    もし GUI.タブ内容(タブ選択, 5) なら
        GUI.ブレッドクラム(["ホーム", "Phase 10-11", "アニメ・追加ウィジェット"])
        GUI.セパレーター()

        // Phase 10: アニメ
        GUI.区切りテキスト("Phase 10: アニメーション・トランジション")
        GUI.横並び開始()
        もし GUI.ボタン("開始") なら
            アニメ有効 = 真
        終わり
        もし GUI.ボタン("停止") なら
            アニメ有効 = 偽
        終わり
        GUI.横並び終了()

        変数 tr値 = GUI.トランジション("test_anim_tr", アニメ有効, 2.0)
        GUI.プログレスバー(tr値 * 100, 100)
        GUI.テキスト("トランジション値: " + 文字列化(tr値))

        変数 anim = GUI.アニメーション("test_bounce", 0, 1, 1.5)
        GUI.テキスト("ループアニメ値: " + 文字列化(anim))

        GUI.スペーサー()
        GUI.区切りテキスト("タイマー (Ph10)")
        GUI.横並び開始()
        もし GUI.ボタン("タイマー開始(2秒)") なら
            タイマーIDval = "timer_test"
            GUI.タイマー("timer_test", 2000, 関数():
                GUI.トースト("タイマー発火！ 2秒経過", 2)
            終わり)
        終わり
        もし GUI.ボタン("タイマー停止") なら
            GUI.タイマー停止("timer_test")
        終わり
        GUI.横並び終了()
        GUI.テキスト("タイマーID: " + タイマーIDval)

        // Phase 11: 追加ウィジェット
        GUI.スペーサー()
        GUI.区切りテキスト("Phase 11: 追加ウィジェット")

        トグル値 = GUI.トグルスイッチ("トグルスイッチ", トグル値)
        GUI.テキスト("トグル値: " + 文字列化(トグル値))

        色値 = GUI.カラーピッカー("カラーピッカー", 色値)

        折りたたみ開 = GUI.折りたたみ("折りたたみ可能なセクション", 折りたたみ開)
        もし 折りたたみ開 なら
            GUI.インデント()
            GUI.テキスト("展開中のコンテンツ OK")
            GUI.テキスト("入れ子にも対応")
            GUI.インデント解除()
        終わり

        GUI.スペーサー()
        選択A = GUI.選択可能("選択可能A", 選択A)
        選択B = GUI.選択可能("選択可能B", 選択B)

        GUI.スペーサー()
        GUI.横並び開始()
        GUI.テキスト("スピナー: ")
        GUI.スピナー()
        GUI.横並び終了()

        もし GUI.リンク("クリック可能なリンク (トースト表示)") なら
            GUI.トースト("リンクがクリックされました", 2)
        終わり

        GUI.スペーサー()
        GUI.横並び開始()
        GUI.テキスト("バッジ: ")
        GUI.バッジ("NEW")
        GUI.バッジ("99+", GUI.色(220, 60, 60, 255))
        GUI.横並び終了()

        GUI.横並び開始()
        GUI.テキスト("タグ: ")
        もし タグ1 なら
            タグ1 = GUI.タグ("はじむ", 真)
        終わり
        もし タグ2 なら
            タグ2 = GUI.タグ("GUI", 真)
        終わり
        GUI.横並び終了()

        GUI.カード開始("テストカード (Ph11)")
        GUI.テキスト("カードコンテンツ")
        GUI.横並び開始()
        もし GUI.小ボタン("詳細") なら
            GUI.トースト("カード内ボタン OK", 1)
        終わり
        GUI.横並び終了()
        GUI.カード終了()
    終わり

    // ══════════════════════════════════════════════════════
    // タブ 6: Phase 12-13 — 高度レイアウト・フォーム拡張
    // ══════════════════════════════════════════════════════
    もし GUI.タブ内容(タブ選択, 6) なら
        GUI.ブレッドクラム(["ホーム", "Phase 12-13", "レイアウト・フォーム"])
        GUI.セパレーター()

        // Phase 12: 高度レイアウト
        GUI.区切りテキスト("Phase 12: 高度レイアウト")
        GUI.グリッド開始(3)
        GUI.ボタン("グリッドA")
        GUI.グリッド次列(3)
        GUI.ボタン("グリッドB")
        GUI.グリッド次列(3)
        GUI.ボタン("グリッドC")
        GUI.グリッド終了(3)

        GUI.スペーサー()
        GUI.区切りテキスト("スプリッター (Ph12)")
        スプリット比 = GUI.スプリッター("test_split", スプリット比)
        GUI.テキスト("スプリット比: " + 文字列化(スプリット比))

        GUI.スペーサー()
        GUI.区切りテキスト("グループ (Ph12)")
        変数 グループ開 = GUI.グループ開始("テストグループ")
        GUI.テキスト("グループ内コンテンツ")
        GUI.ボタン("グループ内ボタン")
        GUI.グループ終了(グループ開)

        GUI.スペーサー()
        GUI.区切りテキスト("スクロール領域 (Ph12)")
        GUI.スクロール領域開始("test_scroll", 200)
        i を 1 から 15 繰り返す
            GUI.テキスト("スクロール可能な行 " + 文字列化(i))
        終わり
        GUI.スクロール領域終了("test_scroll")

        // Phase 13: フォーム拡張
        GUI.スペーサー()
        GUI.区切りテキスト("Phase 13: フォーム入力拡張")
        検索テキスト = GUI.検索入力("検索", 検索テキスト)
        AC値 = GUI.オートコンプリート("AC入力", AC値, ["Apple", "Apricot", "Banana", "Blueberry", "Cherry", "はじむ"])
        ドラッグ値 = GUI.数値ドラッグ("ドラッグ値", ドラッグ値, 0.0, 10.0)
        GUI.テキスト("ドラッグ値: " + 文字列化(ドラッグ値))

        日付値 = GUI.日付ピッカー("日付", 日付値)
        時刻値 = GUI.時間ピッカー("時刻", 時刻値)
        GUI.テキスト("日付:" + 日付値 + "  時刻:" + 時刻値)

        GUI.スペーサー()
        無効フラグ = GUI.チェックボックス("入力を無効化 (Ph13)", 無効フラグ)
        もし 無効フラグ なら
            GUI.無効化開始()
        終わり
        GUI.テキスト入力("無効化テスト", "")
        GUI.ボタン("無効化中ボタン")
        もし 無効フラグ なら
            GUI.無効化終了()
        終わり

        GUI.スペーサー()
        変数 バリデ結果 = テキスト値 != ""
        GUI.バリデーション("テキスト入力 (Ph1タブで入力してください)", バリデ結果)
    終わり

    // ══════════════════════════════════════════════════════
    // タブ 7: Phase 14 — チャート各種
    // ══════════════════════════════════════════════════════
    もし GUI.タブ内容(タブ選択, 7) なら
        GUI.ブレッドクラム(["ホーム", "Phase 14", "チャート"])
        GUI.セパレーター()
        GUI.区切りテキスト("Phase 14: チャート各種")

        GUI.区切りテキスト("折れ線グラフ")
        GUI.折れ線グラフ("test_line", [10, 35, 25, 60, 45, 80, 55, 90, 70, 100])

        GUI.スペーサー()
        GUI.区切りテキスト("棒グラフ")
        GUI.棒グラフ("test_bar", [30, 80, 50, 95, 40, 70])

        GUI.スペーサー()
        GUI.区切りテキスト("円グラフ")
        GUI.円グラフ("test_pie", [40, 30, 20, 10])

        GUI.スペーサー()
        GUI.区切りテキスト("ゲージ")
        GUI.ゲージ(スライダー値, 100, "テストゲージ")

        GUI.スペーサー()
        GUI.区切りテキスト("スパークライン")
        GUI.スパークライン([5, 15, 8, 25, 12, 30, 20], 120, 30)

        GUI.スペーサー()
        GUI.区切りテキスト("ヒストグラム")
        GUI.ヒストグラム("test_hist", [2, 5, 8, 12, 15, 10, 6, 3, 1])

        GUI.スペーサー()
        GUI.区切りテキスト("エリアチャート")
        GUI.エリアチャート("test_area", [20, 45, 30, 70, 55, 85, 60])

        GUI.スペーサー()
        GUI.区切りテキスト("散布図")
        GUI.散布図("test_scatter", [10, 30, 50, 70, 90])
    終わり

    // ══════════════════════════════════════════════════════
    // タブ 8: Phase 15-16 — サブウィンドウ・リッチコンテンツ
    // ══════════════════════════════════════════════════════
    もし GUI.タブ内容(タブ選択, 8) なら
        GUI.ブレッドクラム(["ホーム", "Phase 15-16", "サブウィンドウ・リッチ"])
        GUI.セパレーター()

        // Phase 15
        GUI.区切りテキスト("Phase 15: 子ウィンドウ・ポップアップ")
        GUI.子ウィンドウ開始("child_test", 400, 120)
        GUI.テキスト("子ウィンドウ内コンテンツ (Phase 15) OK")
        GUI.ボタン("子ウィンドウボタン")
        GUI.子ウィンドウ終了()

        GUI.スペーサー()
        もし GUI.ボタン("ポップアップ表示") なら
            GUI.ポップアップ表示("test_popup")
        終わり
        もし GUI.ポップアップ開始("test_popup") なら
            GUI.テキスト("ポップアップコンテンツ OK")
            GUI.テキスト("クリックで閉じます")
            GUI.ポップアップ終了()
        終わり

        GUI.スペーサー()
        GUI.情報バー("情報: Phase 15 の情報バーです", "情報")
        GUI.情報バー("警告: テスト中のため実際の問題ではありません", "警告")

        もし GUI.フローティングボタン(700, 400, "+") なら
            GUI.トースト("フローティングボタン OK", 2)
        終わり

        // Phase 16
        GUI.スペーサー()
        GUI.区切りテキスト("Phase 16: リッチコンテンツ")

        GUI.区切りテキスト("マークダウンレンダリング")
        GUI.マークダウン("## Phase 16\n\n- **マークダウン** 対応\n- _斜体_ テキスト\n- `インラインコード`")

        GUI.スペーサー()
        GUI.区切りテキスト("リッチテキスト")
        GUI.リッチテキスト("**太字** _斜体_ `コード`")

        GUI.スペーサー()
        GUI.区切りテキスト("コードブロック")
        GUI.コードブロック("変数 アプリ = GUI.アプリ作成(\"テスト\", 800, 600)\nGUI.描画ループ(アプリ, 関数():\n    GUI.テキスト(\"Hello World\")\n終わり)\nGUI.アプリ終了(アプリ)", "hajimu")
    終わり

    // ══════════════════════════════════════════════════════
    // タブ 9: Phase 17-19 — システム統合・ナビゲーション
    // ══════════════════════════════════════════════════════
    もし GUI.タブ内容(タブ選択, 9) なら
        GUI.ブレッドクラム(["ホーム", "Phase 17-19", "システム・ナビ"])
        GUI.セパレーター()

        // Phase 17: ウィンドウ操作
        GUI.区切りテキスト("Phase 17: ウィンドウ操作")
        GUI.横並び開始()
        もし GUI.ボタン("最大化") なら
            GUI.ウィンドウ最大化()
        終わり
        もし GUI.ボタン("最小化") なら
            GUI.ウィンドウ最小化()
        終わり
        もし GUI.ボタン("フルスクリーンON") なら
            GUI.フルスクリーン(真)
        終わり
        もし GUI.ボタン("フルスクリーンOFF") なら
            GUI.フルスクリーン(偽)
        終わり
        GUI.横並び終了()

        GUI.横並び開始()
        もし GUI.ボタン("タイトル変更") なら
            GUI.ウィンドウタイトル(アプリ, "hajimu_gui テスト - タイトル変更済 OK")
        終わり
        もし GUI.ボタン("位置(100,100)") なら
            GUI.ウィンドウ位置(100, 100)
        終わり
        もし GUI.ボタン("リサイズ") なら
            GUI.ウィンドウリサイズ(アプリ, 900, 650)
        終わり
        GUI.横並び終了()

        GUI.スペーサー()
        GUI.区切りテキスト("設定の保存・読み込み (Ph17)")
        GUI.横並び開始()
        もし GUI.ボタン("設定保存") なら
            GUI.設定保存("test_key", "保存された値_" + 文字列化(カウンタ))
            GUI.トースト("設定を保存しました", 2)
        終わり
        もし GUI.ボタン("設定読込") なら
            変数 読込値 = GUI.設定読込("test_key")
            GUI.トースト("読込: " + 文字列化(読込値), 2)
        終わり
        GUI.横並び終了()

        GUI.スペーサー()
        GUI.区切りテキスト("Undo / Redo (Ph17)")
        GUI.横並び開始()
        もし GUI.ボタン("元に戻す") なら
            カウンタ = GUI.元に戻す(カウンタ)
            GUI.トースト("元に戻す OK", 1)
        終わり
        もし GUI.ボタン("やり直す") なら
            カウンタ = GUI.やり直す(カウンタ)
            GUI.トースト("やり直す OK", 1)
        終わり
        GUI.横並び終了()

        // Phase 18: アクセシビリティ
        GUI.スペーサー()
        GUI.区切りテキスト("Phase 18: アクセシビリティ・パフォーマンス")
        もし GUI.ボタン("フォーカス設定") なら
            GUI.フォーカス設定("focus_input")
        終わり
        変数 現在フォーカス = GUI.フォーカス取得()
        GUI.テキスト("現在のフォーカス: " + 文字列化(現在フォーカス))
        GUI.テキスト入力("フォーカスターゲット", "")

        GUI.スペーサー()
        GUI.区切りテキスト("仮想スクロール (Ph18) 1000行")
        変数 vs選択 = GUI.仮想スクロール("vs_test", 1000)
        GUI.テキスト("仮想スクロール選択行: " + 文字列化(vs選択))

        // Phase 19: ナビゲーション
        GUI.スペーサー()
        GUI.区切りテキスト("Phase 19: ナビゲーション")
        ナビ選択 = GUI.ナビゲーションバー(["ダッシュボード", "データ", "設定", "ヘルプ"], ナビ選択)
        もし ナビ選択 == 0 なら
            GUI.テキスト("ナビ: ダッシュボード")
        終わり
        もし ナビ選択 == 1 なら
            GUI.テキスト("ナビ: データ")
        終わり
        もし ナビ選択 == 2 なら
            GUI.テキスト("ナビ: 設定")
        終わり
        もし ナビ選択 == 3 なら
            GUI.テキスト("ナビ: ヘルプ")
        終わり

        GUI.スペーサー()
        GUI.区切りテキスト("ステッパー (Ph19)")
        ステッパー値 = GUI.ステッパー(["入力", "確認", "送信", "完了"], ステッパー値)
        GUI.テキスト("ステッパー: ステップ " + 文字列化(ステッパー値))
        GUI.横並び開始()
        もし GUI.ボタン("前へ") なら
            もし ステッパー値 > 1 なら
                ステッパー値 = ステッパー値 - 1
            終わり
        終わり
        もし GUI.ボタン("次へ") なら
            もし ステッパー値 < 4 なら
                ステッパー値 = ステッパー値 + 1
            終わり
        終わり
        GUI.横並び終了()

        GUI.スペーサー()
        GUI.区切りテキスト("ウィザード (Ph19)")
        もし GUI.ウィザード開始(["入力", "確認", "送信", "完了"], ステッパー値) なら
            もし ステッパー値 == 1 なら
                GUI.テキスト("ステップ1: 情報を入力してください")
                テキスト値 = GUI.テキスト入力("名前", テキスト値)
            終わり
            もし ステッパー値 == 2 なら
                GUI.テキスト("ステップ2: 入力内容を確認")
                GUI.テキスト("名前: " + テキスト値)
            終わり
            もし ステッパー値 == 3 なら
                GUI.テキスト("ステップ3: 送信中...")
                GUI.スピナー()
            終わり
            もし ステッパー値 == 4 なら
                GUI.色付きテキスト("完了しました！", GUI.色(60, 200, 100, 255))
            終わり
        終わり
    終わり

    // ── モーダルダイアログ (Ph6) ──
    もし GUI.ダイアログ("全機能テスト - モーダルダイアログ", モーダル表示) なら
        GUI.テキスト("Phase 6 モーダルダイアログ OK")
        GUI.セパレーター()
        GUI.テキスト("このダイアログは背景操作をブロックします。")
        GUI.色付きテキスト("正常表示 -> Phase 6 ダイアログ合格", GUI.色(60, 200, 100, 255))
        GUI.スペーサー()
        GUI.横並び開始()
        もし GUI.ボタン("OK") なら
            モーダル表示 = 偽
            GUI.トースト("ダイアログを閉じました", 2)
        終わり
        もし GUI.ボタン("キャンセル") なら
            モーダル表示 = 偽
        終わり
        GUI.横並び終了()
    終わり

終わり)

// ── 終了処理 ──
GUI.アプリ終了(アプリ)
表示("=== hajimu_gui 全機能テスト 終了 ===")
