// 入れ子の子ウィンドウに置いたキャンバスの文字座標を目視確認する。
// 右側の濃色領域内に、日本語とASCIIの2行が表示されれば成功。
取り込む "hajimu_gui" として GUI

変数 アプリ = GUI.アプリ作成("入れ子キャンバス文字テスト", 900, 520)
変数 画像保存済み = 偽

GUI.描画ループ(アプリ, 関数():
    GUI.横並び開始()

    GUI.子ウィンドウ開始("左ペイン", 320, 440, 真)
    GUI.テキスト("左ペイン")
    GUI.折返しテキスト("右側のキャンバス内に文字が収まることを確認します。")
    GUI.子ウィンドウ終了()

    GUI.子ウィンドウ開始("右ペイン", 520, 440, 真)
    GUI.テキスト("ライブプレビュー")
    GUI.キャンバス開始("入れ子キャンバス", 480, 340)
    GUI.矩形(0, 0, 480, 340, GUI.色(24, 31, 45, 255))
    GUI.描画テキスト("日本語の文字が右ペイン内に表示されます", 32, 60)
    GUI.描画テキスト("Nested canvas text", 32, 108)
    GUI.キャンバス終了()
    GUI.子ウィンドウ終了()

    GUI.横並び終了()

    もし 画像保存済み == 偽 かつ GUI.フレーム数() > 2 なら
        GUI.スクリーンショット("/tmp/hajimu_gui_nested_canvas.ppm")
        画像保存済み = 真
    終わり
終わり)

GUI.アプリ終了(アプリ)
