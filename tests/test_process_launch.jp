取り込む "hajimu_gui" として GUI

変数 出力先 = "/tmp/hajimu_gui_process_launch.txt"
GUI.ファイル削除(出力先)

変数 現在実行系 = GUI.実行ファイルパス()
表明(文字列か(現在実行系) かつ ファイル存在(現在実行系), "現在のHajimu実行ファイルを取得できません")
表明(GUI.executable_path() == 現在実行系, "実行ファイルパスの英語別名が一致しません")

変数 起動済み = GUI.外部プロセス起動("/usr/bin/touch", [出力先])
表明(起動済み, "外部プロセスを起動できません")

変数 確認回数 = 0
確認回数 を 0 から 49 繰り返す
    もし ファイル存在(出力先) なら 抜ける 終わり
    待つ(0.02)
終わり
表明(ファイル存在(出力先), "起動したプロセスが引数を受け取っていません")

表明(GUI.process_launch("/usr/bin/false", []) == 真, "英語別名で起動できません")
表明(GUI.外部プロセス起動("/definitely/missing/hajimu", []) == 偽, "存在しない実行ファイルを成功扱いにしてはいけません")
表明(GUI.外部プロセス起動("/usr/bin/touch", [1]) == 偽, "文字列以外の引数を受け付けてはいけません")

表示("process launch tests passed")
