// 入れ子の子ウィンドウ内でコンボボックスを描画しても、他ペインが欠落しないことを確認する。
取り込む "hajimu_gui" として GUI

変数 アプリ = GUI.アプリ作成("入れ子コンボボックステスト", 900, 520)
変数 選択値 = "項目A"
変数 画像保存済み = 偽

GUI.描画ループ(アプリ, 関数():
    GUI.横並び開始()
    GUI.子ウィンドウ開始("combo_left", 420, 440, 真)
    GUI.見出し("左ペイン", 2)
    GUI.折返しテキスト("この文章と左ペインが欠けずに表示されます。")
    GUI.子ウィンドウ終了()

    GUI.子ウィンドウ開始("combo_right", 420, 440, 真)
    GUI.見出し("右ペイン", 2)
    選択値 = GUI.コンボボックス("選択", ["項目A", "項目B"], 選択値)
    GUI.テキスト("選択中: " + 選択値)
    GUI.子ウィンドウ終了()
    GUI.横並び終了()

    もし 画像保存済み == 偽 かつ GUI.フレーム数() > 2 なら
        GUI.スクリーンショット("/tmp/hajimu_gui_nested_combo.ppm")
        画像保存済み = 真
    終わり
終わり)

GUI.アプリ終了(アプリ)
