取り込む "hajimu_gui" として GUI

変数 アプリ = GUI.アプリ作成("横並びレイアウト回帰テスト", 900, 620)
変数 確認済み = 偽

GUI.描画ループ(アプリ, 関数():
    GUI.見出し("横並びレイアウト", 2)

    GUI.横並び開始()
    GUI.ボタン("最初の操作")
    変数 最初 = GUI.ウィジェット矩形()
    GUI.ボタン("次の操作")
    変数 次 = GUI.ウィジェット矩形()
    GUI.横並び終了()

    GUI.テキスト("この文章はボタン列の下に表示されます")
    変数 ボタン後 = GUI.ウィジェット矩形()

    GUI.横並び開始()
    GUI.子ウィンドウ開始("left_test_panel", 320, 300, 真)
    GUI.テキスト("左パネルの先頭")
    変数 左先頭 = GUI.ウィジェット矩形()
    GUI.横並び開始()
    GUI.小ボタン("左の保存")
    変数 左操作1 = GUI.ウィジェット矩形()
    GUI.小ボタン("左の確認")
    変数 左操作2 = GUI.ウィジェット矩形()
    GUI.横並び終了()
    GUI.折返しテキスト("この文章は内側の操作列より下に表示され、外側の右パネルとは重なりません。")
    変数 左操作後 = GUI.ウィジェット矩形()
    GUI.子ウィンドウ終了()
    変数 左パネル = GUI.ウィジェット矩形()

    GUI.子ウィンドウ開始("right_test_panel", 420, 300, 真)
    GUI.見出し("右パネル", 3)
    GUI.テキスト入力("作品名", "重なりのない画面")
    GUI.折返しテキスト("子パネル内は通常どおり縦方向へ進みます。")
    GUI.子ウィンドウ終了()
    変数 右パネル = GUI.ウィジェット矩形()
    GUI.横並び終了()

    GUI.テキスト("この文章は二つのパネルより下に表示されます")
    変数 パネル後 = GUI.ウィジェット矩形()

    もし 確認済み == 偽 かつ GUI.フレーム数() > 1 なら
        表明(次["x"] >= 最初["x"] + 最初["幅"], "通常ウィジェットが横方向へ進んでいません")
        表明(ボタン後["y"] >= 最初["y"] + 最初["高さ"], "横並び後の本文がボタンと重なっています")
        表明(左先頭["y"] < 左操作1["y"], "子パネル内が縦方向へ進んでいません")
        表明(左操作2["x"] >= 左操作1["x"] + 左操作1["幅"], "子パネル内の横並びが進んでいません")
        表明(左操作後["y"] >= 左操作1["y"] + 左操作1["高さ"], "子パネル内の本文が操作列と重なっています")
        表明(右パネル["x"] >= 左パネル["x"] + 左パネル["幅"], "左右の子パネルが重なっています")
        表明(パネル後["y"] >= 左パネル["y"] + 左パネル["高さ"], "子パネル後の本文がパネルと重なっています")
        表示("horizontal layout tests passed")
        確認済み = 真
    終わり
終わり)

GUI.アプリ終了(アプリ)
