// 制作ツール向けID範囲・分割バー・無効状態の表示回帰テスト。
取り込む "hajimu_gui" として GUI

変数 アプリ = GUI.アプリ作成("制作ツールレイアウトテスト", 960, 560)
変数 左幅 = 280
変数 画像保存済み = 偽

GUI.描画ループ(アプリ, 関数():
    GUI.横並び開始()

    GUI.子ウィンドウ開始("tool_left", 左幅, 470, 真)
    GUI.ID範囲開始("left_actions")
    GUI.見出し("構成", 2)
    GUI.ボタン("追加")
    GUI.無効化開始()
    GUI.ボタン("削除")
    GUI.無効化終了()
    GUI.ID範囲終了()
    GUI.子ウィンドウ終了()

    左幅 = GUI.分割バー("main_split", "垂直", 470, 左幅, 220, 420)

    GUI.子ウィンドウ開始("tool_right", 580, 470, 真)
    GUI.ID範囲開始("right_actions")
    GUI.見出し("編集", 2)
    GUI.ボタン("追加")
    GUI.ボタン("削除")
    GUI.ID範囲終了()
    GUI.子ウィンドウ終了()

    GUI.横並び終了()

    もし 画像保存済み == 偽 かつ GUI.フレーム数() > 2 なら
        GUI.スクリーンショット("/tmp/hajimu_gui_tool_layout.ppm")
        画像保存済み = 真
    終わり
終わり)

GUI.アプリ終了(アプリ)
